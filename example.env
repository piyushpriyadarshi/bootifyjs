# BootifyJS Configuration
# Copy this file to .env and modify values as needed

# Service Configuration
BOOTIFY_SERVICE_NAME=my-awesome-app

# Server Configuration  
BOOTIFY_SERVER_PORT=8080
BOOTIFY_SERVER_HOST=0.0.0.0
BOOTIFY_SERVER_NAME=my-server

# Database Configuration
BOOTIFY_DATABASE_HOST=localhost
BOOTIFY_DATABASE_PORT=5432
BOOTIFY_DATABASE_NAME=myapp
BOOTIFY_DATABASE_USERNAME=postgres
BOOTIFY_DATABASE_PASSWORD=secret123

# Logging Configuration
BOOTIFY_LOGGING_LEVEL=debug
BOOTIFY_LOGGING_ENABLED=true

# ClickHouse Logging Configuration
LOG_CLICKHOUSE_ENABLED=false
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=bootifyjs_logs